{
  "name": "carballo-sap-prestashop-sync",
  "version": "0.1.0",
  "private": true,
  "description": "Sincronizacion SAP HANA a PrestaShop con panel web React.",
  "type": "commonjs",
  "scripts": {
    "start": "powershell -NoProfile -Command \"Clear-Host; git fetch origin; git pull --ff-only origin main\"; npm run build && node server.js",
    "serve": "node server.js",
    "build": "vite build",
    "dev": "vite",
    "mock": "node mock-server.js",
    "sync": "node main.js",
    "test:hana": "node scripts/test-hana.js",
    "lint": "prettier --check \"*.js\" \"src/**/*.js\" \"scripts/**/*.js\"",
    "format": "prettier --write \"*.js\" \"src/**/*.js\" \"scripts/**/*.js\""
  },
  "dependencies": {
    "@sap/hana-client": "^2.25.29",
    "express": "^4.22.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "prettier": "^3.8.4",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
